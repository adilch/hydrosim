# Normalise all text files to LF in the repo; Windows checkouts get CRLF
* text=auto

# Force LF for Python and config files
*.py    text eol=lf
*.toml  text eol=lf
*.qss   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.svg   text eol=lf
*.txt   text eol=lf

# Binary files — never touch line endings
*.ttf   binary
*.png   binary
*.ico   binary
